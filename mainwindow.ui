  <property name="windowTitle">
   <string>BalancinQT — Panel de Control</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* ============ BalancinQT Global Theme ============ */
#centralwidget {
    background-color: #0d1a08;
    background-image: url(:/img/logoUNERsolo.png);
    background-repeat: no-repeat;
    background-position: center;
}
QMenuBar {
    background-color: #111e08;
    color: #b8dfa0;
    border-bottom: 1px solid #3a5f0b;
    padding: 2px;
}
QMenuBar::item {
    background-color: transparent;
    padding: 4px 12px;
    border-radius: 4px;
}
QMenuBar::item:selected { background-color: #2e4c07; }
QMenu {
    background-color: #182e08;
    color: #d0ffcc;
    border: 1px solid #4a6620;
    padding: 4px;
}
QMenu::item {
    padding: 5px 20px 5px 10px;
    border-radius: 3px;
}
QMenu::item:selected { background-color: #3a5f0b; }
QMenu::separator {
    height: 1px;
    background: #3a5f0b;
    margin: 3px 8px;
}
QPushButton {
    color: #e8ffe0;
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #4e6e18, stop:1 #2a4808);
    border: 1px solid #3a5a10;
    border-radius: 6px;
    padding: 5px 12px;
    font-weight: bold;
    font-size: 11px;
}
QPushButton:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #6b8e23, stop:1 #3a5f0b);
    border-color: #7aaa28;
}
QPushButton:pressed {
    background-color: #1e3506;
    border-color: #8aab30;
}
QPushButton:disabled {
    background-color: #1a2a10;
    color: #4a5a3a;
    border-color: #202e12;
}
QPushButton:checked {
    background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #b01010, stop:1 #6a0808);
    border: 2px solid #e04040;
    color: white;
}
QPushButton#btn_UP,
QPushButton#btn_DOWN,
QPushButton#btn_LEFT,
QPushButton#btn_RIGHT {
    font-size: 20px;
    padding: 8px;
    border-radius: 10px;
}
QLabel {
    color: #c8e6a0;
    background-color: transparent;
    border: none;
    padding: 2px 4px;
}
QLabel#label_10, QLabel#label_11, QLabel#label {
    color: #a0d060;
    background-color: rgba(30, 60, 10, 0.45);
    border: 1px solid #3a5f0b;
    border-radius: 5px;
    padding: 5px;
}
QLabel#label_inclination_Xvalue,
QLabel#label_inclination_Yvalue {
    color: #44ffcc;
    background-color: rgba(0, 40, 30, 0.55);
    border: 1px solid #207060;
    border-radius: 5px;
    font-family: Consolas;
    font-weight: bold;
    padding: 4px 8px;
    min-width: 60px;
}
QLabel#label_KP, QLabel#label_KD, QLabel#label_KI,
QLabel#label_KP_LINE, QLabel#label_KD_LINE, QLabel#label_KI_LINE {
    color: #ffe080;
    background-color: rgba(40, 30, 0, 0.55);
    border: 1px solid #706010;
    border-radius: 5px;
    font-family: Consolas;
    padding: 4px 8px;
}
QTextEdit {
    border: 1px solid #3a5f0b;
    border-radius: 8px;
    background-color: rgba(8, 20, 4, 0.90);
    color: #b8e8a0;
    padding: 6px;
    font-family: Consolas;
    selection-background-color: #3a5f0b;
    selection-color: #ffffff;
}
QTextEdit#textEdit_RAW {
    font-size: 12px;
    color: #78b878;
    border-color: #2a4510;
}
QTextEdit#textEdit_PROCCES {
    font-size: 13px;
    color: #c0ffa0;
    border-color: #5a8020;
}
QLineEdit {
    color: #c8ffb0;
    background-color: rgba(8, 25, 4, 0.85);
    border: 1px solid #3a5f0b;
    border-radius: 6px;
    padding: 4px 8px;
    selection-background-color: #3a5f0b;
    selection-color: white;
}
QLineEdit:focus {
    border-color: #7aaa28;
    background-color: rgba(12, 35, 5, 0.95);
}
QLineEdit:read-only {
    color: #78a870;
    background-color: rgba(5, 18, 2, 0.75);
}
QDoubleSpinBox, QSpinBox {
    color: #c8ffb0;
    background-color: rgba(8, 25, 4, 0.85);
    border: 1px solid #3a5f0b;
    border-radius: 6px;
    padding: 4px 8px;
    font-family: Consolas;
    font-size: 12px;
}
QDoubleSpinBox:focus, QSpinBox:focus {
    border-color: #7aaa28;
    background-color: rgba(12, 35, 5, 0.95);
}
QDoubleSpinBox::up-button, QSpinBox::up-button,
QDoubleSpinBox::down-button, QSpinBox::down-button {
    background-color: #2e4c07;
    border: 1px solid #3a5f0b;
    width: 16px;
}
QDoubleSpinBox::up-button:hover, QSpinBox::up-button:hover,
QDoubleSpinBox::down-button:hover, QSpinBox::down-button:hover {
    background-color: #4a7818;
}
QLabel#label_SETPOINT {
    color: #44ffdd;
    background-color: rgba(0, 40, 30, 0.55);
    border: 1px solid #207060;
    border-radius: 6px;
    font-family: Consolas;
    font-weight: bold;
    font-size: 13px;
    padding: 5px 10px;
    qproperty-alignment: AlignCenter;
}
QComboBox {
    color: #d0ffcc;
    background-color: rgba(15, 40, 8, 0.90);
    border: 1px solid #3a5f0b;
    border-radius: 6px;
    padding: 5px 8px;
}
QComboBox:hover { border-color: #6b8e23; }
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 22px;
    border-left: 1px solid #3a5f0b;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
}
QComboBox QAbstractItemView {
    background-color: #182e08;
    border: 1px solid #4a6620;
    color: #d0ffcc;
    selection-background-color: #3a5f0b;
    outline: none;
}
QTabWidget::pane {
    border: 1px solid #3a5f0b;
    border-radius: 5px;
    background-color: rgba(8, 18, 4, 0.70);
    top: -1px;
}
QTabBar::tab {
    background-color: #162a08;
    color: #7a9a60;
    border: 1px solid #263a10;
    border-bottom: none;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    padding: 6px 16px;
    margin-right: 2px;
    font-weight: bold;
    font-size: 11px;
}
QTabBar::tab:selected {
    background-color: rgba(8, 18, 4, 0.70);
    color: #c0ffaa;
    border-color: #5a8020;
    border-bottom: 2px solid #8aab30;
}
QTabBar::tab:hover:!selected {
    background-color: #1e3a0c;
    color: #a0d080;
}
QScrollBar:vertical {
    background-color: #0c180a;
    width: 10px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background-color: #2e5010;
    border-radius: 5px;
    min-height: 24px;
}
QScrollBar::handle:vertical:hover { background-color: #4a7818; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QScrollBar:horizontal {
    background-color: #0c180a;
    height: 10px;
    margin: 0;
}
QScrollBar::handle:horizontal {
    background-color: #2e5010;
    border-radius: 5px;
    min-width: 24px;
}
QScrollBar::handle:horizontal:hover { background-color: #4a7818; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }
QSplitter::handle {
    background-color: #0d1a08;
    image: none;
    border: none;
    width: 4px;
    height: 4px;
    margin: 0px;
}
QSplitter::handle:horizontal {
    background-color: #0d1a08;
    width: 4px;
}
QSplitter::handle:vertical {
    background-color: #0d1a08;
    height: 4px;
}
QSplitter::handle:hover {
    background-color: rgba(90, 128, 32, 0.35);
}
QSplitter::handle:pressed {
    background-color: rgba(138, 171, 48, 0.25);
}
QStatusBar {
    background-color: #0d1a08;
    color: #789060;
    border-top: 1px solid #2a4010;
    font-size: 11px;
}
QStatusBar QLabel {
    border: none;
    background: transparent;
    padding: 2px 6px;
}
QWidget#widget_controls {
    background-color: transparent;
}
QWidget {
    background-color: transparent;
}</string>
